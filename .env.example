# ── API Keys ────────────────────────────────────────────────
# Copy to .env (gitignored) and fill in your values.
# On Railway: set these in your service's Variables tab instead.

# Financial Modeling Prep (required for earnings, economic calendar, screeners)
# Free tier: 250 calls/day — https://site.financialmodelingprep.com/developer/docs
# FMP_API_KEY=your_fmp_key_here

# FINVIZ Elite (optional, speeds up dividend screeners)
# https://elite.finviz.com/
# FINVIZ_API_KEY=your_finviz_key_here

# Alpaca Trading (required for portfolio-manager, optional for parabolic-short)
# Paper trading is free — https://app.alpaca.markets/
ALPACA_API_KEY=your_api_key_id
ALPACA_SECRET_KEY=your_secret_key
ALPACA_PAPER=true
