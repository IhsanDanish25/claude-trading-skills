# Rebuild signal: invalidate Docker cache to pick up fix commits efae759+43c1f77
# (import-typo + FMP bulk earnings endpoint — date below forces re-build)
# Updated: 2026-07-01 10:30
FROM python:3.11-slim

WORKDIR /app

# Install deps
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy all code
COPY . .

# Make modules importable
RUN touch routines/__init__.py core/__init__.py

# Worker service: trading daemon (no PORT needed)
CMD ["python3", "worker.py"]
